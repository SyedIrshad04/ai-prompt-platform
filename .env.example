# ── Django ───────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings
DJANGO_SECRET_KEY=change-me-to-a-long-random-string-in-production
# Set to False in production (Railway/Render)
DEBUG=False
# Use * for Railway/Render, or your specific domain
ALLOWED_HOSTS=*

# ── Database ──────────────────────────────────────────────
# Option A — full URL (Railway / Render / Heroku style)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Option B — individual vars (local Docker Compose)
DB_NAME=promptdb
DB_USER=promptuser
DB_PASSWORD=promptpass
DB_HOST=db
DB_PORT=5432

# ── Redis ─────────────────────────────────────────────────
# Option A — full URL (Railway / Render)
# REDIS_URL=redis://default:password@host:6379

# Option B — local Docker Compose
REDIS_URL=redis://redis:6379/0

# ── CORS (comma-separated, tighten in production) ─────────
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://localhost:4200

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=change-me-jwt-secret-also-long-and-random
JWT_EXPIRY_HOURS=24

# ── Frontend port (host-side mapping) ─────────────────────
FRONTEND_PORT=80
